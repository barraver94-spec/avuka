        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ template_id: $json.template_id, form_data: (() => { try { return typeof $json.form_data === 'string' ? JSON.parse($json.form_data) : $json.form_data; } catch(e) { return {}; } })() }) }}"
      }
    },
