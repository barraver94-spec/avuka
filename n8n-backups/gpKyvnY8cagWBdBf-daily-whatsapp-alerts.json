    {
      "id": "a3a567c1-c174-4edd-ae39-cadc0bee42ec",
      "name": "Sticky Note ad349bd4",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [560, 256],
      "parameters": {
        "content": "## ⚙️ Setup Required\n\n**Twilio WhatsApp From number:**\nChange `whatsapp:+14155238886` to your approved Twilio WhatsApp sender number.\n\nTo use Twilio sandbox: join the sandbox first at console.twilio.com\n\n**Base44 API Key:**\nSame credential as Workflow 1.",
        "color": 3
