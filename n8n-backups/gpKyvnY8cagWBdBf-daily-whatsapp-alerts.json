    },
    {
      "id": "3e189a06-8179-4c3b-ac78-2d418be6ba20",
      "name": "Filter Next 14 Days",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, 96],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const today = new Date();\ntoday.setHours(0,0,0,0);\nconst in14 = new Date(today);\nin14.setDate(in14.getDate() + 14);\n\nconst filtered = $input.all().filter(item => {\n  const d = item.json.next_inspection_date;\n  if (!d) return false;\n  const dt = new Date(d);\n  dt.setHours(0,0,0,0);\n  return dt >= today && dt <= in14;\n});\n\nreturn filtered;"
      }
    }
