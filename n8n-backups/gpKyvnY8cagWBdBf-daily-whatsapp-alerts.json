    {
      "id": "37e11fcc-0986-4005-a377-d6d760dbe0a8",
      "name": "Format WhatsApp Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [896, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst today = new Date().toLocaleDateString('he-IL');\n\nlet lines = ['*🔥 ביקורות כיבוי אש קרובות*', `תאריך: ${today}`, ''];\n\nfor (const item of items) {\n  const d = item.json;\n  const date = d.next_inspection_date || 'לא ידוע';\n  const name = d.customer_name || d.customer_id || 'לא ידוע';\n  const site = d.site_name ? ` — ${d.site_name}` : '';\n  const daysLeft = d.next_inspection_date\n    ? Math.round((new Date(d.next_inspection_date) - new Date()) / 86400000)\n    : null;\n  const daysStr = daysLeft !== null ? ` (${daysLeft} ימים)` : '';\n  lines.push(`⏳ ${name}${site} | ${date}${daysStr}`);\n}\n\nlines.push('');\nlines.push(`סה\"כ: ${items.length} ביקורות`);\n\nreturn [{ json: { message: lines.join('\\n'), count: items.length } }];"
      }
    },
    {
