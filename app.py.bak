def _yn(val):
    """Boolean → תקין / לא תקין."""
    if val is None or val == '':
        return ''
    return 'תקין' if bool(val) else 'לא תקין'


def _check(val):
    """Boolean → ✓ / empty."""
    return '✓' if bool(val) else ''


def _safe_json(s, default=None):
    """Parse JSON string safely, return default on failure."""
    if default is None:
        default = []
    if not s:
        return default
    try:
        return json.loads(s)
    except Exception:
        return default


